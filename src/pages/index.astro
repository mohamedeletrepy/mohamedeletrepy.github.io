---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const featuredPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 4);
---

<BaseLayout title="Home">
  <!-- ========= HERO ========= -->
  <section class="hero">
    <div class="container">
      <div class="hero__inner">
        <p class="hero__label animate-fade-up animate-delay-1">
          Security Researcher & Adversary Simulation
        </p>

        <h1 class="hero__title animate-fade-up animate-delay-2">
          <span class="name">Mohamed Eletrepy</span>
        </h1>

        <p class="hero__tagline animate-fade-up animate-delay-2">
          <span class="highlight">Red Teaming</span> / Adversary Simulation / Web & Network Pentesting
        </p>

        <p class="hero__desc animate-fade-up animate-delay-3">
          Security researcher with a deep passion for red teaming, adversary simulation,
          and low-level internals. I write about Active Directory attacks, Windows offensive
          techniques, network security, and red team threat intelligence.
        </p>

        <div class="hero__actions animate-fade-up animate-delay-4">
          <a href="/blog" class="btn btn--primary">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
              <polyline points="14 2 14 8 20 8"/>
            </svg>
            Read the Blog
          </a>
          <a href="/about" class="btn btn--outline">
            About Me →
          </a>
        </div>

        <div class="hero__stats animate-fade-up animate-delay-4">
          <div class="stat">
            <span class="stat__number">{allPosts.length}</span>
            <span class="stat__label">Posts</span>
          </div>
          <div class="stat">
            <span class="stat__number" style="font-size:1rem">AD</span>
            <span class="stat__label">Red Team</span>
          </div>
          <div class="stat">
            <span class="stat__number" style="font-size:1rem">Web</span>
            <span class="stat__label">Pentest</span>
          </div>
          <div class="stat">
            <span class="stat__number" style="font-size:1rem">API</span>
            <span class="stat__label">Pentest</span>
          </div>
          <div class="stat">
            <span class="stat__number" style="font-size:1rem">AI</span>
            <span class="stat__label">Red Team</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========= TERMINAL 1: PowerShell whoami ========= -->
  <section class="section" style="padding-top: 0; padding-bottom: 1.5rem">
    <div class="container">
      <div class="terminal animate-fade-up">
        <div class="terminal__header">
          <div class="terminal__dot terminal__dot--red"></div>
          <div class="terminal__dot terminal__dot--yellow"></div>
          <div class="terminal__dot terminal__dot--green"></div>
          <span class="terminal__title">PowerShell — maverick</span>
          <span style="margin-left:auto; font-size:0.68rem; color:var(--text-dim); font-family:var(--font-mono);">Windows PowerShell 5.1</span>
        </div>
        <div class="terminal__body">
          <div class="terminal__line">
            <span class="terminal__prompt" style="color:#5fa8e8">PS C:\Users\maverick&gt;&nbsp;</span>
            <span class="terminal__cmd">[System.Security.Principal.WindowsIdentity]::GetCurrent() | Select-Object -Property *</span>
          </div>

          <div style="margin-top:0.75rem; display:grid; grid-template-columns: 180px 1fr; gap:0.2rem 0.5rem; padding-left:0;">
            <span style="color:var(--accent-green); font-family:var(--font-mono); font-size:0.83rem;">Name</span>
            <span style="color:var(--text-primary); font-family:var(--font-mono); font-size:0.83rem;">Mohamed Eletrepy</span>

            <span style="color:var(--accent-green); font-family:var(--font-mono); font-size:0.83rem;">Handle</span>
            <span style="color:var(--accent-purple); font-family:var(--font-mono); font-size:0.83rem;">maverick</span>

            <span style="color:var(--accent-green); font-family:var(--font-mono); font-size:0.83rem;">Role</span>
            <span style="color:var(--text-secondary); font-family:var(--font-mono); font-size:0.83rem;">Security Researcher</span>

            <span style="color:var(--accent-green); font-family:var(--font-mono); font-size:0.83rem;">Domains</span>
            <span style="color:var(--text-secondary); font-family:var(--font-mono); font-size:0.83rem;">AD, Windows, Network, Web, AI Security</span>

            <span style="color:var(--accent-green); font-family:var(--font-mono); font-size:0.83rem;">Passion</span>
            <span style="color:var(--text-secondary); font-family:var(--font-mono); font-size:0.83rem;">Red Teaming, Adversary Simulation, Low-Level, Threat Intel</span>

            <span style="color:var(--accent-green); font-family:var(--font-mono); font-size:0.83rem;">Courses</span>
            <span style="color:var(--text-secondary); font-family:var(--font-mono); font-size:0.83rem;">CPTS (HTB), CWEE (HTB), OSCP, CRTP, CRTE</span>

            <span style="color:var(--accent-green); font-family:var(--font-mono); font-size:0.83rem;">Status</span>
            <span style="color:#4ade80; font-family:var(--font-mono); font-size:0.83rem;">Learning. Breaking. Documenting.</span>
          </div>

          <div class="terminal__line" style="margin-top:0.9rem">
            <span class="terminal__prompt" style="color:#5fa8e8">PS C:\Users\maverick&gt;&nbsp;</span>
            <span class="terminal__cursor"></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========= TERMINAL 2: Kerberoasting ========= -->
  <section class="section" style="padding-top: 0">
    <div class="container">
      <div class="terminal animate-fade-up">
        <div class="terminal__header">
          <div class="terminal__dot terminal__dot--red"></div>
          <div class="terminal__dot terminal__dot--yellow"></div>
          <div class="terminal__dot terminal__dot--green"></div>
          <span class="terminal__title">bash — maverick@kali</span>
        </div>
        <div class="terminal__body">
          <div class="terminal__line">
            <span class="terminal__prompt">┌──(maverick㉿kali)-[~]</span>
          </div>
          <div class="terminal__line">
            <span class="terminal__prompt">└─$&nbsp;</span>
            <span class="terminal__cmd">python3 GetUserSPNs.py corp.local/jdoe -dc-ip 192.168.1.10 -request</span>
          </div>
          <div class="terminal__line" style="padding-left: 0">
            <span class="terminal__output">ServicePrincipalName      Name        MemberOf</span>
          </div>
          <div class="terminal__line" style="padding-left: 0">
            <span class="terminal__output">MSSQLSvc/db01.corp.local  svc_mssql   Domain Users</span>
          </div>
          <div class="terminal__line" style="padding-left: 0">
            <span class="terminal__output" style="color: var(--accent-green)">$krb5tgs$23$*svc_mssql$CORP.LOCAL$MSSQLSvc...*$a1b2c3d4e5f6...</span>
          </div>
          <div class="terminal__line" style="margin-top: 0.5rem">
            <span class="terminal__prompt">└─$&nbsp;</span>
            <span class="terminal__cursor"></span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ========= FEATURED POSTS ========= -->
  <section class="section">
    <div class="container">
      <div class="section__header">
        <div>
          <div class="section__title">Latest Research</div>
          <h2 class="section__heading">Featured Posts</h2>
        </div>
        <a href="/blog" class="section__link">
          All posts
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="5" y1="12" x2="19" y2="12"/>
            <polyline points="12 5 19 12 12 19"/>
          </svg>
        </a>
      </div>

      <div class="posts-grid">
        {featuredPosts.map(post => (
          <PostCard post={post} />
        ))}
      </div>
    </div>
  </section>

  <!-- ========= RESEARCH AREAS ========= -->
  <section class="section" style="padding-top: 0; padding-bottom: 3rem">
    <div class="container">
      <div class="section__title" style="margin-bottom: 1rem">Research Areas</div>

      <div class="research-areas">
        {[
          { icon: '🏰', title: 'Active Directory', desc: 'Kerberos abuse, ACL exploitation, DCSync, ADCS, lateral movement through AD trust chains.' },
          { icon: '🪟', title: 'Windows Internals', desc: 'Low-level exploitation, process injection, token manipulation, EDR evasion, kernel-mode attacks.' },
          { icon: '🌐', title: 'Network Security', desc: 'Protocol-level attacks, MITM, network pivoting, C2 infrastructure, traffic analysis.' },
          { icon: '🕵️', title: 'Red Team Threat Intel', desc: 'APT tradecraft analysis, TTPs mapping to MITRE ATT&CK, adversary emulation planning.' },
          { icon: '🌐', title: 'Web Pentesting', desc: 'SQL injection, XSS, SSRF, authentication bypasses, JWT attacks, OAuth misconfigs, API security.' },
          { icon: '🔌', title: 'Network Pentesting', desc: 'NTLM relay, SMB attacks, protocol abuse, pivoting, C2 infrastructure, traffic evasion.' },
          { icon: '🤖', title: 'AI & Security', desc: 'LLM security research, AI-assisted red teaming, prompt injection, and AI system exploitation.' },
          { icon: '🔩', title: 'Low-Level & Malware Dev', desc: 'Shellcode development, PE internals, custom C2 tooling, offensive tooling from scratch.' },
        ].map(area => (
          <div class="research-card">
            <div class="research-card__icon">{area.icon}</div>
            <div class="research-card__title">{area.title}</div>
            <div class="research-card__desc">{area.desc}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ========= TOPICS ========= -->
  <section class="section" style="padding-top: 0; padding-bottom: 6rem">
    <div class="container">
      <div class="section__title" style="margin-bottom: 1.5rem">Topics I Write About</div>
      <div style="display: flex; flex-wrap: wrap; gap: 0.6rem;">
        {[
          'Active Directory', 'Kerberos', 'DCSync', 'ACL Abuse',
          'Windows Internals', 'Token Manipulation', 'Process Injection',
          'Red Team Ops', 'Adversary Simulation', 'MITRE ATT&CK',
          'Threat Intelligence', 'C2 Frameworks', 'OPSEC', 'Malware Dev',
          'Network Attacks', 'Web Security', 'AI Security', 'Low-Level Exploitation'
        ].map(topic => (
          <span class="tag" style="font-size: 0.78rem; padding: 0.3rem 0.75rem;">{topic}</span>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
.research-areas {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
  gap: 1rem;
  margin-bottom: 2rem;
}

.research-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 10px;
  padding: 1.25rem 1.5rem;
  transition: all 0.25s ease;
  position: relative;
  overflow: hidden;
}
.research-card::before {
  content: '';
  position: absolute;
  left: 0; top: 0; bottom: 0;
  width: 2px;
  background: var(--accent-green);
  opacity: 0;
  transition: opacity 0.25s;
}
.research-card:hover {
  border-color: var(--border-bright);
  background: var(--bg-card-hover);
  transform: translateY(-2px);
}
.research-card:hover::before { opacity: 1; }
.research-card__icon { font-size: 1.4rem; margin-bottom: 0.6rem; }
.research-card__title {
  font-family: var(--font-mono);
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--accent-green);
  margin-bottom: 0.4rem;
  letter-spacing: 0.03em;
}
.research-card__desc { font-size: 0.82rem; color: var(--text-muted); line-height: 1.6; }
</style>
